<%- include('partials/layout_top', { pageTitle: 'Statistik', activeMenu: 'statistik', admin }) %>

<div class="stats-grid" style="margin-bottom:24px">
  <div class="stat-card fade-in">
    <div class="stat-icon green">📝</div>
    <div class="stat-info"><strong><%= stats.total %></strong><span>Total Laporan</span></div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.05s">
    <div class="stat-icon blue">🆕</div>
    <div class="stat-info"><strong><%= stats.baru %></strong><span>Laporan Baru</span></div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.1s">
    <div class="stat-icon orange">🔄</div>
    <div class="stat-info"><strong><%= stats.proses %></strong><span>Diproses</span></div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.15s">
    <div class="stat-icon green">✅</div>
    <div class="stat-info"><strong><%= stats.selesai %></strong><span>Selesai</span></div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.2s">
    <div class="stat-icon red">❌</div>
    <div class="stat-info"><strong><%= stats.ditolak %></strong><span>Ditolak</span></div>
  </div>
</div>

<div class="grid-2" style="gap:20px;align-items:start">

  <!-- Laporan per Kategori -->
  <div class="chart-container fade-in">
    <strong style="font-size:15px;display:block;margin-bottom:18px">📊 Laporan per Kategori</strong>
    <% const kategoriList = [
      { label: '😈 Siswa Nakal', key: 'siswa-nakal' },
      { label: '🗑️ Kebersihan',  key: 'kebersihan'  },
      { label: '⚡ Kejadian',    key: 'kejadian'     },
      { label: '🏚️ Fasilitas',  key: 'fasilitas'    },
      { label: '📢 Lainnya',     key: 'lainnya'      },
    ];
    const maxKat = Math.max(...kategoriList.map(k => stats.perKategori?.[k.key] || 0), 1);
    %>
    <% kategoriList.forEach(k => { const c = stats.perKategori?.[k.key] || 0; %>
    <div class="chart-bar-row">
      <div class="chart-bar-label" style="font-size:13px"><%= k.label %></div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill" style="width:<%= Math.round(c/maxKat*100) %>%">
          <% if(c > 0){ %><span><%= c %></span><% } %>
        </div>
      </div>
      <div class="chart-bar-count"><%= c %></div>
    </div>
    <% }) %>
  </div>

  <!-- Laporan per Status -->
  <div class="chart-container fade-in" style="animation-delay:.1s">
    <strong style="font-size:15px;display:block;margin-bottom:18px">📋 Laporan per Status</strong>
    <% const statusList = [
      { label: '🆕 Baru',     key: 'baru',    color: '#2980b9' },
      { label: '🔄 Proses',   key: 'proses',  color: '#e67e22' },
      { label: '✅ Selesai',  key: 'selesai', color: '#27ae60' },
      { label: '❌ Ditolak',  key: 'ditolak', color: '#c0392b' },
    ];
    const maxStat = Math.max(stats.baru, stats.proses, stats.selesai, stats.ditolak, 1);
    %>
    <% statusList.forEach(s => { const c = stats[s.key] || 0; %>
    <div class="chart-bar-row">
      <div class="chart-bar-label" style="font-size:13px"><%= s.label %></div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill" style="width:<%= Math.round(c/maxStat*100) %>;background:<%= s.color %>">
          <% if(c > 0){ %><span><%= c %></span><% } %>
        </div>
      </div>
      <div class="chart-bar-count"><%= c %></div>
    </div>
    <% }) %>
  </div>

  <!-- Laporan per Bulan -->
  <div class="chart-container fade-in" style="animation-delay:.15s;grid-column:span 2">
    <strong style="font-size:15px;display:block;margin-bottom:18px">📅 Laporan 6 Bulan Terakhir</strong>
    <% const maxBulan = Math.max(...bulanan.map(b => b.jumlah), 1); %>
    <div style="display:flex;align-items:flex-end;gap:10px;height:160px;padding-bottom:28px;position:relative">
      <% bulanan.forEach(b => { %>
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;justify-content:flex-end">
        <span style="font-size:12px;font-weight:700;color:var(--green)"><%= b.jumlah %></span>
        <div style="width:100%;background:var(--green);border-radius:6px 6px 0 0;height:<%= Math.round(b.jumlah/maxBulan*100) %>%;min-height:<%= b.jumlah > 0 ? '8px' : '2px' %>;transition:height 0.6s;opacity:<%= b.jumlah > 0 ? '1' : '0.2' %>"></div>
        <span style="font-size:11px;color:var(--text-muted);white-space:nowrap"><%= b.bulan %></span>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Laporan per Kelas -->
  <div class="chart-container fade-in" style="animation-delay:.2s">
    <strong style="font-size:15px;display:block;margin-bottom:18px">🏫 Laporan per Kelas (Top 8)</strong>
    <% const maxKelas = Math.max(...perKelas.map(k => k.jumlah), 1); %>
    <% perKelas.forEach(k => { %>
    <div class="chart-bar-row">
      <div class="chart-bar-label" style="font-size:13px">Kelas <%= k.kelas %></div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill" style="width:<%= Math.round(k.jumlah/maxKelas*100) %>%">
          <% if(k.jumlah > 0){ %><span><%= k.jumlah %></span><% } %>
        </div>
      </div>
      <div class="chart-bar-count"><%= k.jumlah %></div>
    </div>
    <% }) %>
  </div>

  <!-- Masukan Guru -->
  <div class="chart-container fade-in" style="animation-delay:.25s">
    <strong style="font-size:15px;display:block;margin-bottom:18px">👨‍🏫 Statistik Masukan Guru</strong>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
      <div style="background:var(--green-pale);border-radius:var(--radius-sm);padding:16px;text-align:center;border:1px solid var(--green-border)">
        <strong style="font-size:28px;display:block;color:var(--green)"><%= statsGuru.total %></strong>
        <span style="font-size:13px;color:var(--text-muted)">Total Masukan</span>
      </div>
      <div style="background:var(--green-pale);border-radius:var(--radius-sm);padding:16px;text-align:center;border:1px solid var(--green-border)">
        <strong style="font-size:28px;display:block;color:var(--green)"><%= parseFloat(statsGuru.avgRating || 0).toFixed(1) %></strong>
        <span style="font-size:13px;color:var(--text-muted)">Rata-rata Rating</span>
      </div>
    </div>
    <% const ratingDist = [5,4,3,2,1];
    const maxRating = Math.max(...ratingDist.map(r => statsGuru['r'+r] || 0), 1); %>
    <% ratingDist.forEach(r => { const c = statsGuru['r'+r] || 0; %>
    <div class="chart-bar-row">
      <div class="chart-bar-label" style="font-size:13px"><%= '★'.repeat(r) %></div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill" style="width:<%= Math.round(c/maxRating*100) %>%;background:#f39c12">
          <% if(c > 0){ %><span><%= c %></span><% } %>
        </div>
      </div>
      <div class="chart-bar-count"><%= c %></div>
    </div>
    <% }) %>
  </div>

</div>

<%- include('partials/layout_bottom') %>
