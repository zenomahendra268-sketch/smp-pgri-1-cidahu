<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Admin — SMP PGRI 1 CIDAHU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="login-page">
  <div class="login-card fade-in">
    <div class="login-logo">
      <div class="logo-circle">
        <img src="/images/logo.png" alt="Logo" onerror="this.parentElement.textContent='SMP'">
      </div>
      <h2>SMP PGRI 1 CIDAHU</h2>
      <p>Panel Admin — Masuk untuk melanjutkan</p>
    </div>

    <% if (error) { %>
    <div class="alert alert-danger" style="margin-bottom:20px">
      <span>❌</span> <%= error %>
    </div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Masukkan username" required autofocus>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Masukkan password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg" style="margin-top:8px">
        🔐 Masuk
      </button>
    </form>

    <p style="text-align:center;margin-top:20px;font-size:13px;color:var(--text-muted)">
      <a href="/">← Kembali ke Beranda</a>
    </p>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
