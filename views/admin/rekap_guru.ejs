<%- include('partials/layout_top', { pageTitle: 'Rekap Rating Guru', activeMenu: 'rekap', admin }) %>

<% if (rekapGuru.length === 0) { %>
<div style="text-align:center;padding:60px;background:var(--white);border-radius:var(--radius);border:1px solid var(--border)">
  <div style="font-size:48px;margin-bottom:16px">📭</div>
  <p style="color:var(--text-muted)">Belum ada masukan guru</p>
</div>
<% } else { %>
<div class="grid-3">
  <% rekapGuru.forEach((g, i) => { %>
  <div class="guru-card fade-in" style="animation-delay:<%= i*0.06 %>s">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
      <div style="width:48px;height:48px;background:var(--green-pale);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;border:2px solid var(--green-border);flex-shrink:0">👨‍🏫</div>
      <div>
        <strong style="font-size:15px"><%= g.nama_guru %></strong><br>
        <span style="font-size:13px;color:var(--text-muted)"><%= g.mata_pelajaran %></span>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
      <div class="stars" style="font-size:20px">
        <% for(let s=1;s<=5;s++) { %>
          <span style="color:<%= s <= Math.round(g.avg_rating) ? '#f39c12' : '#ddd' %>">★</span>
        <% } %>
      </div>
      <strong style="font-size:20px;color:<%= g.avg_rating >= 4 ? 'var(--success)' : g.avg_rating >= 3 ? 'var(--warning)' : 'var(--danger)' %>">
        <%= parseFloat(g.avg_rating).toFixed(1) %>
      </strong>
    </div>

    <div style="font-size:13px;color:var(--text-muted);margin-bottom:12px">
      📊 <%= g.jumlah %> masukan dari siswa
    </div>

    <!-- Mini bar chart rating -->
    <% for(let r=5;r>=1;r--) { %>
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
      <span style="font-size:11px;width:12px;text-align:right"><%= r %></span>
      <div style="flex:1;background:var(--border);border-radius:10px;height:10px;overflow:hidden">
        <div style="width:<%= g.jumlah > 0 ? Math.round((g['r'+r]||0)/g.jumlah*100) : 0 %>%;background:var(--green);height:100%;border-radius:10px;transition:width 0.6s"></div>
      </div>
      <span style="font-size:11px;width:20px;color:var(--text-muted)"><%= g['r'+r]||0 %></span>
    </div>
    <% } %>
  </div>
  <% }) %>
</div>
<% } %>

<%- include('partials/layout_bottom') %>
