<%- include('partials/layout_top', { pageTitle: 'Detail Laporan', activeMenu: 'laporan', admin }) %>

<div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap">
  <a href="/admin/laporan" class="btn btn-outline btn-sm">← Kembali</a>
  <span class="badge badge-<%= laporan.status %>" style="align-self:center;font-size:13px;padding:6px 14px"><%= laporan.status.toUpperCase() %></span>
  <span class="badge badge-<%= laporan.kategori %>" style="align-self:center;font-size:13px;padding:6px 14px"><%= laporan.kategori %></span>
</div>

<div class="grid-2" style="align-items:start">

  <!-- Detail Laporan -->
  <div class="card fade-in" style="padding:0;overflow:hidden">
    <div style="background:var(--green-pale);padding:18px 24px;border-bottom:2px solid var(--green-border)">
      <h3 style="font-size:17px"><%= laporan.judul %></h3>
      <div style="font-size:13px;color:var(--text-muted);margin-top:4px">
        📅 <%= new Date(laporan.created_at).toLocaleDateString('id-ID', {weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
      </div>
    </div>
    <div style="padding:24px">

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
        <div style="background:var(--bg);border-radius:var(--radius-sm);padding:14px">
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px">👤 PELAPOR</div>
          <strong><%= laporan.nama_pelapor %></strong>
        </div>
        <div style="background:var(--bg);border-radius:var(--radius-sm);padding:14px">
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px">🏫 KELAS</div>
          <strong><%= laporan.kelas %></strong>
        </div>
        <% if (laporan.kode_tracking) { %>
        <div style="background:var(--bg);border-radius:var(--radius-sm);padding:14px;grid-column:span 2">
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px">🔑 KODE TRACKING</div>
          <strong style="letter-spacing:2px;color:var(--green)"><%= laporan.kode_tracking %></strong>
        </div>
        <% } %>
      </div>

      <div style="margin-bottom:20px">
        <div style="font-size:12px;color:var(--text-muted);margin-bottom:8px;font-weight:700">📄 DESKRIPSI</div>
        <div style="background:var(--bg);border-radius:var(--radius-sm);padding:16px;font-size:14px;line-height:1.7">
          <%= laporan.deskripsi %>
        </div>
      </div>

      <% if (laporan.foto) { %>
      <div>
        <div style="font-size:12px;color:var(--text-muted);margin-bottom:8px;font-weight:700">📷 FOTO BUKTI</div>
        <div class="foto-grid">
          <% laporan.foto.split(',').filter(Boolean).forEach(f => { %>
          <img src="<%= f.trim() %>" alt="Foto bukti" onclick="openLightbox('<%= f.trim() %>')">
          <% }) %>
        </div>
      </div>
      <% } %>

    </div>
  </div>

  <!-- Update Status -->
  <div style="display:flex;flex-direction:column;gap:16px">
    <div class="card fade-in" style="animation-delay:.1s">
      <h4 style="margin-bottom:16px;font-size:15px">🔧 Update Status Laporan</h4>
      <form action="/admin/laporan/<%= laporan.id %>/update" method="POST">
        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="baru" <%= laporan.status === 'baru' ? 'selected' : '' %>>🆕 Baru</option>
            <option value="proses" <%= laporan.status === 'proses' ? 'selected' : '' %>>🔄 Sedang Diproses</option>
            <option value="selesai" <%= laporan.status === 'selesai' ? 'selected' : '' %>>✅ Selesai</option>
            <option value="ditolak" <%= laporan.status === 'ditolak' ? 'selected' : '' %>>❌ Ditolak</option>
          </select>
        </div>
        <div class="form-group">
          <label>Catatan Admin (akan dilihat pelapor)</label>
          <textarea name="catatan_admin" rows="4" placeholder="Tulis tindakan yang diambil atau alasan penolakan..."><%= laporan.catatan_admin || '' %></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-block">💾 Simpan Perubahan</button>
      </form>
    </div>

    <div class="card" style="border-color:var(--danger)">
      <h4 style="margin-bottom:12px;font-size:14px;color:var(--danger)">⚠️ Hapus Laporan</h4>
      <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px">Tindakan ini tidak dapat dibatalkan.</p>
      <form action="/admin/laporan/<%= laporan.id %>/hapus" method="POST">
        <button type="submit" class="btn btn-danger btn-block btn-sm" data-confirm="Yakin ingin menghapus laporan ini? Tindakan tidak bisa dibatalkan!">
          🗑️ Hapus Laporan
        </button>
      </form>
    </div>
  </div>

</div>

<%- include('partials/layout_bottom') %>
