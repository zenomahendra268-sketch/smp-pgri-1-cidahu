<%- include('partials/layout_top', { pageTitle: 'Dashboard', activeMenu: 'dashboard', admin, stats }) %>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card fade-in">
    <div class="stat-icon green">📝</div>
    <div class="stat-info">
      <strong><%= stats.total %></strong>
      <span>Total Laporan</span>
    </div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.05s">
    <div class="stat-icon blue">🆕</div>
    <div class="stat-info">
      <strong><%= stats.baru %></strong>
      <span>Laporan Baru</span>
    </div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.1s">
    <div class="stat-icon orange">🔄</div>
    <div class="stat-info">
      <strong><%= stats.proses %></strong>
      <span>Sedang Diproses</span>
    </div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.15s">
    <div class="stat-icon green">✅</div>
    <div class="stat-info">
      <strong><%= stats.selesai %></strong>
      <span>Selesai</span>
    </div>
  </div>
  <div class="stat-card fade-in" style="animation-delay:.2s">
    <div class="stat-icon purple">👨‍🏫</div>
    <div class="stat-info">
      <strong><%= stats.masukan %></strong>
      <span>Masukan Guru</span>
    </div>
  </div>
</div>

<div class="grid-2" style="gap:20px">

  <!-- Laporan Terbaru -->
  <div class="card fade-in" style="padding:0;overflow:hidden">
    <div style="padding:18px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
      <strong style="font-size:15px">📝 Laporan Terbaru</strong>
      <a href="/admin/laporan" class="btn btn-outline btn-sm">Lihat Semua</a>
    </div>
    <% if (laporanTerbaru.length === 0) { %>
    <div style="padding:40px;text-align:center;color:var(--text-muted)">Belum ada laporan</div>
    <% } else { %>
    <% laporanTerbaru.forEach(l => { %>
    <a href="/admin/laporan/<%= l.id %>" style="display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid var(--border);transition:background 0.2s;color:var(--text);" onmouseover="this.style.background='var(--green-pale)'" onmouseout="this.style.background=''">
      <div style="width:36px;height:36px;border-radius:var(--radius-sm);background:var(--green-pale);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">
        <%= l.kategori === 'siswa-nakal' ? '😈' : l.kategori === 'kebersihan' ? '🗑️' : l.kategori === 'kejadian' ? '⚡' : l.kategori === 'fasilitas' ? '🏚️' : '📢' %>
      </div>
      <div style="flex:1;min-width:0">
        <div style="font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= l.judul %></div>
        <div style="font-size:12px;color:var(--text-muted)"><%= l.kelas %> · <%= new Date(l.created_at).toLocaleDateString('id-ID') %></div>
      </div>
      <span class="badge badge-<%= l.status %>"><%= l.status %></span>
    </a>
    <% }) %>
    <% } %>
  </div>

  <!-- Grafik Kategori -->
  <div class="chart-container fade-in" style="animation-delay:.1s">
    <strong style="font-size:15px;display:block;margin-bottom:18px">📊 Laporan per Kategori</strong>
    <% const kategoriData = [
      { label: '😈 Siswa Nakal', key: 'siswa-nakal', count: stats.perKategori?.['siswa-nakal'] || 0 },
      { label: '🗑️ Kebersihan', key: 'kebersihan', count: stats.perKategori?.['kebersihan'] || 0 },
      { label: '⚡ Kejadian', key: 'kejadian', count: stats.perKategori?.['kejadian'] || 0 },
      { label: '🏚️ Fasilitas', key: 'fasilitas', count: stats.perKategori?.['fasilitas'] || 0 },
      { label: '📢 Lainnya', key: 'lainnya', count: stats.perKategori?.['lainnya'] || 0 },
    ];
    const maxCount = Math.max(...kategoriData.map(k => k.count), 1);
    %>
    <% kategoriData.forEach(k => { %>
    <div class="chart-bar-row">
      <div class="chart-bar-label"><%= k.label %></div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill" style="width:<%= Math.round(k.count/maxCount*100) %>%">
          <% if (k.count > 0) { %><span><%= k.count %></span><% } %>
        </div>
      </div>
      <div class="chart-bar-count"><%= k.count %></div>
    </div>
    <% }) %>
  </div>

</div>

<!-- Quick Actions -->
<div style="margin-top:20px;background:var(--white);border-radius:var(--radius);border:1px solid var(--border);padding:20px">
  <strong style="font-size:15px;display:block;margin-bottom:14px">⚡ Aksi Cepat</strong>
  <div style="display:flex;flex-wrap:wrap;gap:10px">
    <a href="/admin/laporan?status=baru" class="btn btn-primary">🆕 Laporan Baru (<%= stats.baru %>)</a>
    <a href="/admin/pengumuman/buat" class="btn btn-outline">📢 Buat Pengumuman</a>
    <a href="/admin/laporan/export?format=csv" class="btn btn-outline">📥 Export CSV</a>
    <a href="/admin/statistik" class="btn btn-outline">📈 Statistik</a>
  </div>
</div>

<%- include('partials/layout_bottom') %>
