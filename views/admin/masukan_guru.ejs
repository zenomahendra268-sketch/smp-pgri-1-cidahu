<%- include('partials/layout_top', { pageTitle: 'Masukan Guru', activeMenu: 'masukan', admin }) %>

<% if (masukan.length === 0) { %>
<div style="text-align:center;padding:60px;background:var(--white);border-radius:var(--radius);border:1px solid var(--border)">
  <div style="font-size:48px;margin-bottom:16px">📭</div>
  <p style="color:var(--text-muted)">Belum ada masukan guru</p>
</div>
<% } else { %>

<div style="margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
  <span style="font-size:14px;color:var(--text-muted)"><%= masukan.length %> masukan ditemukan</span>
  <a href="/admin/rekap-guru" class="btn btn-outline btn-sm">⭐ Lihat Rekap Rating</a>
</div>

<% masukan.forEach((m, i) => { %>
<div class="card fade-in" style="margin-bottom:14px;animation-delay:<%= i*0.04 %>s">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px">
    <div>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:8px">
        <strong style="font-size:15px">👨‍🏫 <%= m.nama_guru %></strong>
        <span style="background:var(--green-pale);color:var(--green);border:1px solid var(--green-border);border-radius:20px;padding:2px 10px;font-size:12px"><%= m.mata_pelajaran %></span>
        <div class="stars">
          <% for(let s=1;s<=5;s++) { %>
            <span class="<%= s <= m.rating ? 'stars' : 'stars-empty' %>">★</span>
          <% } %>
        </div>
        <span style="font-size:12px;font-weight:700;color:<%= m.rating >= 4 ? 'var(--success)' : m.rating >= 3 ? 'var(--warning)' : 'var(--danger)' %>"><%= m.rating %>/5</span>
      </div>
      <div style="font-size:13px;color:var(--text-muted);margin-bottom:10px">
        👤 <strong><%= m.nama %></strong> · Kelas <%= m.kelas || '-' %> ·
        📅 <%= new Date(m.created_at).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %>
      </div>
      <p style="font-size:14px;background:var(--bg);padding:12px 16px;border-radius:var(--radius-sm)"><%= m.pesan %></p>

      <% if (m.reply_admin) { %>
      <div class="reply-box">
        <strong style="font-size:12px">💬 Balasan Admin:</strong>
        <p style="margin-top:4px;font-size:13px"><%= m.reply_admin %></p>
      </div>
      <% } %>

      <!-- Reply Form -->
      <details style="margin-top:12px">
        <summary style="cursor:pointer;font-size:13px;color:var(--green);font-weight:700">💬 <%= m.reply_admin ? 'Edit Balasan' : 'Balas Masukan' %></summary>
        <form action="/admin/masukan-guru/<%= m.id %>/reply" method="POST" style="margin-top:10px">
          <div style="display:flex;gap:8px">
            <textarea name="reply" rows="2" style="flex:1;font-size:13px" placeholder="Tulis balasan untuk masukan ini..."><%= m.reply_admin || '' %></textarea>
            <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-end">Kirim</button>
          </div>
        </form>
      </details>
    </div>

    <form action="/admin/masukan-guru/<%= m.id %>/hapus" method="POST">
      <button type="submit" class="btn btn-danger btn-sm" data-confirm="Hapus masukan ini?">🗑️</button>
    </form>
  </div>
</div>
<% }) %>

<% } %>

<%- include('partials/layout_bottom') %>
