<%- include('partials/layout_top', { pageTitle: 'Pengumuman', activeMenu: 'pengumuman', admin }) %>

<% if (typeof sukses !== 'undefined' && sukses) { %>
<div class="alert alert-success fade-in" style="margin-bottom:16px"><span>✅</span> <%= sukses %></div>
<% } %>

<div class="grid-2" style="align-items:start">

  <!-- Form Buat Pengumuman -->
  <div class="card fade-in">
    <h4 style="margin-bottom:16px;font-size:15px">📢 <%= typeof editPengumuman !== 'undefined' && editPengumuman ? 'Edit Pengumuman' : 'Buat Pengumuman Baru' %></h4>
    <form action="/admin/pengumuman/<%= typeof editPengumuman !== 'undefined' && editPengumuman ? editPengumuman.id + '/update' : 'buat' %>" method="POST">
      <div class="form-group">
        <label>Judul <span class="req">*</span></label>
        <input type="text" name="judul" required maxlength="200" placeholder="Judul pengumuman"
          value="<%= typeof editPengumuman !== 'undefined' && editPengumuman ? editPengumuman.judul : '' %>">
      </div>
      <div class="form-group">
        <label>Isi Pengumuman <span class="req">*</span></label>
        <textarea name="isi" required rows="5" placeholder="Isi lengkap pengumuman..."><%= typeof editPengumuman !== 'undefined' && editPengumuman ? editPengumuman.isi : '' %></textarea>
      </div>
      <div class="form-group">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" name="penting" value="1" style="width:auto" <%= typeof editPengumuman !== 'undefined' && editPengumuman?.penting ? 'checked' : '' %>>
          🔔 Tandai sebagai PENTING
        </label>
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        📤 <%= typeof editPengumuman !== 'undefined' && editPengumuman ? 'Update' : 'Publikasikan' %>
      </button>
      <% if (typeof editPengumuman !== 'undefined' && editPengumuman) { %>
      <a href="/admin/pengumuman" class="btn btn-outline btn-block" style="margin-top:8px">Batal</a>
      <% } %>
    </form>
  </div>

  <!-- Daftar Pengumuman -->
  <div>
    <% if (pengumuman.length === 0) { %>
    <div style="text-align:center;padding:40px;background:var(--white);border-radius:var(--radius);border:1px solid var(--border)">
      <p style="color:var(--text-muted)">Belum ada pengumuman</p>
    </div>
    <% } else { %>
      <% pengumuman.forEach((p, i) => { %>
      <div class="pengumuman-item fade-in" style="animation-delay:<%= i*0.05 %>s">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">
          <div style="flex:1">
            <% if (p.penting) { %><span class="badge badge-baru" style="margin-bottom:6px;display:inline-block">🔔 PENTING</span><% } %>
            <h4><%= p.judul %></h4>
            <p style="margin-top:4px"><%= p.isi.substring(0, 120) %><%= p.isi.length > 120 ? '...' : '' %></p>
            <div class="pengumuman-meta">
              <span>📅 <%= new Date(p.created_at).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %></span>
            </div>
          </div>
          <div style="display:flex;gap:6px;flex-shrink:0">
            <a href="/admin/pengumuman/<%= p.id %>/edit" class="btn btn-outline btn-sm">✏️</a>
            <form action="/admin/pengumuman/<%= p.id %>/hapus" method="POST">
              <button class="btn btn-danger btn-sm" data-confirm="Hapus pengumuman ini?">🗑️</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

</div>

<%- include('partials/layout_bottom') %>
