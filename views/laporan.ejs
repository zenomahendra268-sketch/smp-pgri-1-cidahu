<%- include('partials/header', { title: 'Buat Laporan', activePage: 'laporan' }) %>

<section class="section">
  <div class="container">

    <% if (sukses) { %>
    <div class="alert alert-success fade-in" style="max-width:720px;margin:0 auto 24px">
      <div>
        <strong>Laporan Berhasil Dikirim</strong><br>
        <%= sukses %><br>
        <% if (kode) { %>
        <div class="tracking-box" style="margin-top:14px">
          <p style="font-size:13px;color:var(--text-muted)">Simpan kode ini untuk melacak status laporanmu:</p>
          <div class="kode" id="kodeTracking"><%= kode %></div>
          <button class="btn btn-outline btn-sm" id="copyBtn" onclick="copyKode('<%= kode %>')">Salin Kode</button>
          <p style="font-size:12px;color:var(--text-muted);margin-top:8px">Gunakan kode ini di halaman <a href="/cek-laporan">Cek Laporan</a></p>
        </div>
        <% } %>
      </div>
    </div>
    <% } %>

    <% if (error) { %>
    <div class="alert alert-danger fade-in" style="max-width:720px;margin:0 auto 24px">
      <%= error %>
    </div>
    <% } %>

    <!-- Clerk Gate: tampil form atau minta login -->
    <% if (clerkEnabled && clerkPublishableKey) { %>
    <div id="clerk-gate" style="display:none;max-width:720px;margin:0 auto 24px;text-align:center;padding:40px;background:var(--bg-secondary,#f8f8f8);border-radius:12px;border:1px solid var(--border)">
      <p style="font-size:18px;font-weight:600;margin-bottom:8px">Masuk untuk Membuat Laporan</p>
      <p style="color:var(--text-muted);margin-bottom:20px">Kamu perlu masuk dengan akun Google terlebih dahulu untuk mengirim laporan.</p>
      <a href="/masuk" class="btn btn-primary">Masuk dengan Google</a>
    </div>
    <div id="laporan-form" style="display:none">
    <% } %>

    <div class="form-card fade-in">
      <div class="form-title">Buat Laporan</div>
      <div class="form-subtitle">Laporanmu bersifat rahasia. Identitasmu hanya diketahui oleh admin sekolah.</div>

      <form action="/laporan" method="POST" enctype="multipart/form-data">

        <div class="form-row">
          <div class="form-group">
            <label>Nama <span class="req">*</span></label>
            <input type="text" name="nama_pelapor" placeholder="Nama lengkapmu" required maxlength="100">
            <div class="form-hint">Hanya admin yang dapat melihat namamu</div>
          </div>
          <div class="form-group">
            <label>Kelas <span class="req">*</span></label>
            <select name="kelas" required>
              <option value="">-- Pilih Kelas --</option>
              <optgroup label="Kelas 7">
                <option>7A</option><option>7B</option><option>7C</option><option>7D</option>
              </optgroup>
              <optgroup label="Kelas 8">
                <option>8A</option><option>8B</option><option>8C</option><option>8D</option>
              </optgroup>
              <optgroup label="Kelas 9">
                <option>9A</option><option>9B</option><option>9C</option><option>9D</option>
              </optgroup>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label>Kategori Laporan <span class="req">*</span></label>
          <select name="kategori" required>
            <option value="">-- Pilih Kategori --</option>
            <option value="siswa-nakal">Siswa Nakal / Perundungan</option>
            <option value="kebersihan">Kebersihan</option>
            <option value="kejadian">Kejadian Sekolah</option>
            <option value="fasilitas">Fasilitas Rusak</option>
            <option value="lainnya">Lainnya</option>
          </select>
        </div>

        <div class="form-group">
          <label>Judul Laporan <span class="req">*</span></label>
          <input type="text" name="judul" placeholder="Contoh: Ada siswa membuang sampah sembarangan di toilet" required maxlength="200">
        </div>

        <div class="form-group">
          <label>Deskripsi Lengkap <span class="req">*</span></label>
          <textarea name="deskripsi" placeholder="Ceritakan secara detail: apa yang terjadi, kapan, di mana, siapa yang terlibat..." required minlength="20" rows="6"></textarea>
          <div class="form-hint">Semakin detail, semakin mudah ditindaklanjuti</div>
        </div>

        <div class="form-group">
          <label>Foto Bukti (Opsional, maks. 3 foto)</label>
          <div class="upload-area" id="uploadArea">
            <input type="file" name="foto" id="fotoInput" accept="image/*" multiple>
            <div class="upload-icon">&#128247;</div>
            <p><strong>Klik atau seret foto ke sini</strong></p>
            <p>Format: JPG, PNG, WEBP &mdash; Maks 5MB per foto</p>
          </div>
          <div class="preview-grid" id="previewGrid"></div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg btn-block">
          Kirim Laporan
        </button>
      </form>
    </div>

    <% if (clerkEnabled && clerkPublishableKey) { %>
    </div><!-- #laporan-form -->
    <script>
    window.addEventListener('load', async () => {
      await window.Clerk?.load();
      if (window.Clerk?.user) {
        document.getElementById('laporan-form').style.display = 'block';
      } else {
        document.getElementById('clerk-gate').style.display = 'block';
      }
    });
    </script>
    <% } %>

  </div>
</section>

<%- include('partials/footer') %>
