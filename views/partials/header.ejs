<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#FF5C00">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>SMP PGRI 1 CIDAHU</title>
  <link rel="manifest" href="/manifest.json">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.png" type="image/png">
  <% if (clerkEnabled && clerkPublishableKey) { %>
  <script async crossorigin="anonymous"
    data-clerk-publishable-key="<%= clerkPublishableKey %>"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js">
  </script>
  <% } %>
</head>
<body>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <span class="lightbox-close" onclick="closeLightbox()">&#x2715;</span>
  <img id="lightboxImg" src="" alt="Foto">
</div>

<!-- Navbar -->
<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">
      <span class="navbar-wordmark">🎓 SMP PGRI 1 CIDAHU</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="navbar-nav" id="navMenu">
      <li><a href="/" class="<%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>">Beranda</a></li>
      <li><a href="/laporan" class="<%= typeof activePage !== 'undefined' && activePage === 'laporan' ? 'active' : '' %>">Buat Laporan</a></li>
      <li><a href="/masukan-guru" class="<%= typeof activePage !== 'undefined' && activePage === 'masukan' ? 'active' : '' %>">Masukan Guru</a></li>
      <li><a href="/cek-laporan" class="<%= typeof activePage !== 'undefined' && activePage === 'cek' ? 'active' : '' %>">Cek Laporan</a></li>
    </ul>

    <div class="navbar-actions">
      <% if (clerkEnabled && clerkPublishableKey) { %>
      <div id="clerk-user-area"></div>
      <% } %>
    </div>

    <!-- Hamburger -->
    <button class="navbar-hamburger" id="hamburgerBtn" onclick="toggleMobileMenu()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" class="<%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>">🏠 Beranda</a>
  <a href="/laporan" class="<%= typeof activePage !== 'undefined' && activePage === 'laporan' ? 'active' : '' %>">📝 Buat Laporan</a>
  <a href="/masukan-guru" class="<%= typeof activePage !== 'undefined' && activePage === 'masukan' ? 'active' : '' %>">👨‍🏫 Masukan Guru</a>
  <a href="/cek-laporan" class="<%= typeof activePage !== 'undefined' && activePage === 'cek' ? 'active' : '' %>">🔍 Cek Laporan</a>
</div>

<script>
function toggleMobileMenu() {
  const menu = document.getElementById('mobileMenu');
  const btn = document.getElementById('hamburgerBtn');
  menu.classList.toggle('open');
  btn.classList.toggle('open');
}
document.addEventListener('click', function(e) {
  const menu = document.getElementById('mobileMenu');
  const btn = document.getElementById('hamburgerBtn');
  if (!menu.contains(e.target) && !btn.contains(e.target)) {
    menu.classList.remove('open');
    btn.classList.remove('open');
  }
});
</script>
