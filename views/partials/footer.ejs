<script src="/js/main.js"></script>
<% if (clerkEnabled && clerkPublishableKey) { %>
<script>
window.addEventListener('load', async () => {
  await window.Clerk?.load();
  const area = document.getElementById('clerk-user-area');
  if (!area) return;
  if (window.Clerk?.user) {
    window.Clerk.mountUserButton(area);
  } else {
    area.innerHTML = '<a href="/masuk" class="btn btn-outline btn-sm">Masuk</a>';
  }
});
</script>
<% } %>
</body>
</html>
