<%- include('partials/header', { title: 'Beranda', activePage: 'home' }) %>

<!-- Hero -->
<section class="hero">
  <div class="hero-content fade-in">
    <div class="hero-wordmark">🎓 SMP PGRI 1 CIDAHU</div>
    <h1>Portal Sekolah</h1>
    <p>Wadah aspirasi, laporan, dan masukan untuk sekolah yang lebih baik</p>
    <div class="hero-stats">
      <div class="hero-stat">
        <strong><%= totalLaporan %></strong>
        <span>Total Laporan</span>
      </div>
      <div class="hero-stat">
        <strong><%= totalMasukan %></strong>
        <span>Masukan Guru</span>
      </div>
      <div class="hero-stat">
        <strong>24/7</strong>
        <span>Tersedia</span>
      </div>
    </div>
  </div>
</section>

<!-- Fitur Utama -->
<section class="section">
  <div class="container">
    <div class="section-title">Layanan Portal</div>
    <div class="section-sub">Pilih layanan yang sesuai kebutuhanmu</div>

    <div class="grid-3">
      <div class="card fade-in">
        <div class="card-icon">📝</div>
        <h3>Laporan Kejadian</h3>
        <p>Laporkan siswa nakal, kejadian di sekolah, masalah kebersihan, kerusakan fasilitas, dan hal lainnya secara anonim.</p>
        <a href="/laporan" class="card-link">Buat Laporan &rarr;</a>
      </div>

      <div class="card fade-in" style="animation-delay:0.1s">
        <div class="card-icon">👨‍🏫</div>
        <h3>Masukan untuk Guru</h3>
        <p>Berikan masukan dan saran agar guru bisa mengajar lebih baik. Identitasmu tetap terjaga.</p>
        <a href="/masukan-guru" class="card-link">Beri Masukan &rarr;</a>
      </div>

      <div class="card fade-in" style="animation-delay:0.2s">
        <div class="card-icon">🔍</div>
        <h3>Cek Status Laporan</h3>
        <p>Gunakan kode unik yang kamu terima saat melapor untuk memantau perkembangan laporanmu.</p>
        <a href="/cek-laporan" class="card-link">Cek Sekarang &rarr;</a>
      </div>

      <div class="card fade-in" style="animation-delay:0.3s">
        <div class="card-icon">🔒</div>
        <h3>Laporan Anonim</h3>
        <p>Identitasmu hanya diketahui admin. Laporkan dengan aman tanpa takut diketahui teman-teman.</p>
        <span style="color:var(--orange);font-size:13px;margin-top:16px;display:block;font-weight:800;text-transform:uppercase;letter-spacing:0.5px;">✓ Dijamin Aman</span>
      </div>

      <div class="card fade-in" style="animation-delay:0.4s">
        <div class="card-icon">⚡</div>
        <h3>Respon Cepat</h3>
        <p>Admin sekolah akan segera menindaklanjuti setiap laporan yang masuk dengan serius.</p>
        <span style="color:var(--orange);font-size:13px;margin-top:16px;display:block;font-weight:800;text-transform:uppercase;letter-spacing:0.5px;">✓ Ditindaklanjuti</span>
      </div>

      <div class="card fade-in" style="animation-delay:0.5s">
        <div class="card-icon">📋</div>
        <h3>Kategori Lengkap</h3>
        <p>Tersedia berbagai kategori laporan: kenakalan, kebersihan, fasilitas rusak, kejadian sekolah, dan lainnya.</p>
        <a href="/laporan" class="card-link">Lihat Kategori &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- Kategori Laporan -->
<section class="section section-stripe">
  <div class="container">
    <div class="section-title">Kategori Laporan</div>
    <div class="section-sub">Berbagai jenis laporan yang bisa kamu sampaikan</div>

    <div class="grid-3">
      <div class="category-item fade-in">
        <span class="category-emoji">😤</span>
        <div>
          <strong>Siswa Nakal</strong><br>
          <span style="font-size:13px;color:var(--text-muted);font-weight:500">Perundungan, tawuran, dan sejenisnya</span>
        </div>
      </div>
      <div class="category-item fade-in">
        <span class="category-emoji">🧹</span>
        <div>
          <strong>Kebersihan</strong><br>
          <span style="font-size:13px;color:var(--text-muted);font-weight:500">Toilet kotor, sampah menumpuk, dll</span>
        </div>
      </div>
      <div class="category-item fade-in">
        <span class="category-emoji">🚨</span>
        <div>
          <strong>Kejadian Sekolah</strong><br>
          <span style="font-size:13px;color:var(--text-muted);font-weight:500">Insiden, kecelakaan, kejadian darurat</span>
        </div>
      </div>
      <div class="category-item fade-in">
        <span class="category-emoji">🔧</span>
        <div>
          <strong>Fasilitas Rusak</strong><br>
          <span style="font-size:13px;color:var(--text-muted);font-weight:500">Meja rusak, listrik mati, atap bocor</span>
        </div>
      </div>
      <div class="category-item fade-in">
        <span class="category-emoji">📌</span>
        <div>
          <strong>Lainnya</strong><br>
          <span style="font-size:13px;color:var(--text-muted);font-weight:500">Hal lain yang perlu dilaporkan</span>
        </div>
      </div>
      <a href="/laporan" class="btn btn-primary btn-block fade-in" style="min-height:70px;font-size:15px;justify-content:center;">
        📝 Buat Laporan Sekarang
      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section">
  <div class="container" style="text-align:center">
    <div style="background:var(--white);border:4px solid var(--black);box-shadow:var(--shadow-lg);padding:48px 32px;max-width:600px;margin:0 auto;">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:clamp(18px,3vw,24px);letter-spacing:2px;color:var(--orange);margin-bottom:14px;">🎓 SMP PGRI 1 CIDAHU</div>
      <h2 style="font-size:clamp(24px,5vw,36px);margin-bottom:12px;font-family:'Bebas Neue',sans-serif;text-transform:uppercase;letter-spacing:2px;">Bersama Membangun<br>Sekolah Lebih Baik</h2>
      <p style="color:var(--text-muted);max-width:420px;margin:0 auto 28px;font-weight:500">Setiap laporan dan masukan yang kamu berikan sangat berarti untuk kemajuan SMP PGRI 1 CIDAHU.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/laporan" class="btn btn-primary btn-lg">📝 Buat Laporan</a>
        <a href="/masukan-guru" class="btn btn-outline btn-lg">👨‍🏫 Masukan Guru</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
